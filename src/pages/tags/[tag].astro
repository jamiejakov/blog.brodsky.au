---
import { getPosts } from '@/lib/sortedCollection';

import PageLayout from '../../layouts/PageLayout.astro';
import { exists } from '../../lib/exists';
import { groupPostsByYearMonth } from '../../lib/postsByYearMonth';

export async function getStaticPaths() {
  const allPosts = await getPosts();
  const uniqueTags = [
    ...new Set(
      allPosts
        .map((post) => post.data.tags)
        .filter(exists)
        .flat()
    ),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));

    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

type Props = Awaited<ReturnType<typeof getStaticPaths>>[number]['props'];

const { tag } = Astro.params;
const { posts } = Astro.props;

const pageTitle = `Tag: ${tag}`;
const sortedGroups = groupPostsByYearMonth(posts);
---

<PageLayout pageTitle={pageTitle} className="flex flex-col gap-10 px-6">
  <h2 class="text-2xl font-medium mb-3">
    Explore all posts tagged with <strong>{tag}</strong>{' '}
    <span class="text-muted-foreground font-normal">({posts.length})</span>
  </h2>
  <div class="flex flex-col gap-8">
    {
      sortedGroups.map(([, { heading, posts: groupPosts }]) => (
        <section>
          <h2 class="text-xl font-bold mb-3">{heading}</h2>
          <ul class="list-none pl-4 space-y-2">
            {groupPosts.map((post) => (
              <li>
                <span class="font-mono">{String(post.data.pubDate.getDate()).padStart(2, '0')}:</span>{' '}
                <a href={`/posts/${post.id}/`} class="hover:underline text-primary">
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</PageLayout>
