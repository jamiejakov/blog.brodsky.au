---
import { BlogPagination } from '@/components/BlogPagination';
import MdPreviewPostLayout from '@/layouts/MdPreviewPostLayout.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import type { GetStaticPathsOptions } from 'astro';

import { POSTS_PER_PAGE } from '../../lib/constants';
import { getPosts } from '../../lib/sortedCollection';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allPosts = await getPosts();
  const notFirstPosts = allPosts.slice(POSTS_PER_PAGE);
  return paginate(notFirstPosts, { pageSize: POSTS_PER_PAGE });
}

type Props = Awaited<ReturnType<typeof getStaticPaths>>[number]['props'];

const { page } = Astro.props;
---

<PageLayout pageTitle={`Blog Page - ${page.currentPage}`} className="flex flex-col gap-40">
  {page.data.map((post) => <MdPreviewPostLayout post={post} />)}
  <BlogPagination url={page.url} currentPage={page.currentPage} />
</PageLayout>
