---
import { FullBlogLinkButton } from '@/components/FullBlogLinkButton';
import MdPreviewPostLayout from '@/layouts/MdPreviewPostLayout.astro';

import PageLayout from '../layouts/PageLayout.astro';
import { POSTS_PER_PAGE } from '../lib/constants';
import { getPosts } from '../lib/sortedCollection';

const pageTitle = '';
const allPosts = await getPosts(POSTS_PER_PAGE);
---

<PageLayout
  pageTitle={pageTitle}
  showBlogWelcome={true}
  className="flex flex-col gap-40"
  ogDescription="The life and times of Vadim Brodsky, with engineering opinions, landscape photographs, travel pieces, and more"
  ogImage="/ogimage.jpg"
>
  {allPosts.map((post) => <MdPreviewPostLayout post={post} />)}
  <FullBlogLinkButton />
</PageLayout>
