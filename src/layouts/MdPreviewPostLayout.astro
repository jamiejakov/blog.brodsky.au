---
import Excerpt from '@/components/Excerpt.astro';
import { Image } from 'astro:assets';
import { PostReadMoreButton, PostTitleLinkButton } from '@/components/PostLinkButton';
import { cn } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const maxTextWidth = 'max-w-3xl w-full';
---

<article class="flex flex-col items-center gap-3">
  {
    post.data.image && (
      <Image
        src={post.data.image.src}
        alt={post.data.image.alt}
        class="max-h-120 w-full object-cover bg-center border-t border-b md:border border-primary"
      />
    )
  }
  <div class="flex flex-col items-center w-full">
    <h2 class={cn(maxTextWidth, 'px-2 md:px-0 text-2xl font-bold')}>
      <PostTitleLinkButton id={post.id} title={post.data.title} />
    </h2>
    <span class={cn(maxTextWidth, 'px-6 md:px-4 text-gray-500 italic')}>
      {post.data.pubDate.toLocaleDateString('en-au')}
    </span>
  </div>
  <div class={cn(maxTextWidth, 'px-6 md:px-4 flex flex-col gap-2')}>
    <Excerpt post={post} />
    <PostReadMoreButton id={post.id} />
  </div>
</article>
