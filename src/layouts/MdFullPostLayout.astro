---
import { getImage, Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

import { Category } from '../components/Category';
import PhotoSwipeClient from '../components/PhotoSwipeClient';
import Tag from '../components/Tag.astro';
import PageLayout from './PageLayout.astro';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const ogImageSrc = post.data.image ? (await getImage(post.data.image)).src : undefined;
---

<PageLayout
  pageTitle={post.data.title}
  className="flex flex-col items-center"
  ogDescription={post.data.description}
  ogImage={ogImageSrc}
>
  {
    post.data.image && (
      <Image
        src={post.data.image.src}
        alt={post.data.image.alt}
        class="max-h-120 w-full object-cover bg-center border-t border-b md:border border-primary"
      />
    )
  }
  <article class="full-post flex flex-col px-6 mt-4 max-w-3xl w-full">
    <h1 class="text-3xl font-bold mb-3">{post.data.title}</h1>
    <div>Published on: <span class="text-gray-500 italic">{post.data.pubDate.toLocaleDateString('en-au')}</span></div>
    <p class="mb-1">Written by: <span class="text-gray-500 italic">{post.data.author}</span></p>
    {
      post.data.categories.length > 0 && (
        <div class="mb-1 flex items-center gap-2">
          {post.data.categories.length === 1 ? 'Category' : 'Categories'}:{' '}
          <ul class="flex flex-wrap gap-1 list-none m-0 pl-0">
            {post.data.categories.map((cat: string) => (
              <li>
                <Category category={cat} client:load />
              </li>
            ))}
          </ul>
        </div>
      )
    }
    {
      post.data.tags.length > 0 && (
        <div class="flex items-center gap-2">
          <span>Tags:</span>
          <ul class="flex flex-wrap list-none m-0 pl-0">
            {post.data.tags.map((tag: string, index: number) => (
              <li class="flex gap-2">
                {index > 0 && ', '}
                <Tag tag={tag} />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <div class="mt-8">
      <slot />
    </div>
  </article>

  <PhotoSwipeClient client:load />
</PageLayout>

<script
  is:inline
  define:vars={{
    postTitle: post.data.title,
    postAuthor: post.data.author,
    postCategories: post.data.categories,
    postTags: post.data.tags,
  }}
>
  window.posthog?.capture('post_viewed', {
    title: postTitle,
    author: postAuthor,
    categories: postCategories,
    tags: postTags,
  });
</script>
