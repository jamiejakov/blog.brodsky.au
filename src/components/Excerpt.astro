---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<div class="excerpt-content">
  <Content />
</div>

<script>
  function truncateExcerpts() {
    document.querySelectorAll('.excerpt-content').forEach((container) => {
      const hr = container.querySelector('hr');
      if (!hr) return;

      // Start from hr - if it has siblings after it, hide those; otherwise hide its parent and following siblings
      let start: Element = hr;
      if (!hr.nextElementSibling && hr.parentElement && hr.parentElement !== container) {
        start = hr.parentElement;
      }

      start.setAttribute('hidden', '');
      let el: Element | null = start.nextElementSibling;
      while (el) {
        el.setAttribute('hidden', '');
        el = el.nextElementSibling;
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', truncateExcerpts);
  } else {
    truncateExcerpts();
  }
</script>
